# ============================================================
# GE-Ponto — Variáveis de Ambiente
# ============================================================
# Renomeie este arquivo para .env.local e preencha com seus dados reais.
# O arquivo .env.local é ignorado pelo Git (já está no .gitignore).
# NUNCA commite chaves reais no repositório!
# ============================================================

# --- Firebase ---
# Encontre em: console.firebase.google.com > Configurações do projeto > Seus apps
VITE_FIREBASE_API_KEY=AIzaSy-COLOQUE-SUA-CHAVE-AQUI
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef

# --- Gemini (opcional, apenas se usar recursos de IA) ---
# Encontre em: aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=AIzaSy-COLOQUE-SUA-CHAVE-GEMINI-AQUI
